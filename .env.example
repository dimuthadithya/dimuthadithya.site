# Public site config
NEXT_PUBLIC_SITE_URL=YOUR_PUBLIC_SITE_URL_HERE
NEXT_PUBLIC_GITHUB_URL=YOUR_PUBLIC_GITHUB_URL_HERE
NEXT_PUBLIC_ICON_URL=YOUR_PUBLIC_ICON_URL_HERE
NEXT_PUBLIC_LINKEDIN_URL=YOUR_PUBLIC_LINKEDIN_URL

# GitHub data fetcher (used by: npm run fetch-github)
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN_HERE
GITHUB_USERNAME=YOUR_GITHUB_USERNAME_HERE
# Comma-separated list of GitHub topic tags — repos with ANY matching tag are included
GITHUB_PROJECT_TAGS=portfolio,project,showcase